@prefix cepr: <https://cepraea.app/ontology#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

cepr:GamePeriodDurationShape a sh:NodeShape ;
  sh:targetClass cepr:GamePeriod ;
  sh:property [
    sh:path cepr:durationMinutes ;
    sh:datatype xsd:integer ;
    sh:hasValue 10 ;
    sh:message "GamePeriod deve ter duracao de 10 minutos."@pt-BR ;
  ] .

cepr:GoalShape a sh:NodeShape ;
  sh:targetClass cepr:Goal ;
  sh:property [
    sh:path cepr:hasShootingAction ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:class cepr:ShootingAction ;
    sh:message "Goal deve referenciar exatamente uma ShootingAction canonica."@pt-BR ;
  ] ;
  sh:property [
    sh:path cepr:hasCourtZone ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:class cepr:CourtZone ;
    sh:message "Goal deve registrar exatamente uma zona de quadra."@pt-BR ;
  ] ;
  sh:property [
    sh:path cepr:points ;
    sh:datatype xsd:integer ;
    sh:in ( 1 2 ) ;
    sh:message "Goal deve ter 1 ou 2 pontos."@pt-BR ;
  ] .

cepr:SpinThrowTwoPointsShape a sh:NodeShape ;
  sh:targetClass cepr:Goal ;
  sh:sparql [
    sh:message "Goal com SpinThrow deve ter exatamente 2 pontos."@pt-BR ;
    sh:select """
      PREFIX cepr: <https://cepraea.app/ontology#>
      SELECT $this
      WHERE {
        $this cepr:hasShootingAction ?action ;
              cepr:points ?points .
        ?action a cepr:SpinThrow .
        FILTER(?points != 2)
      }
    """ ;
  ] .

cepr:AerialThrowTwoPointsShape a sh:NodeShape ;
  sh:targetClass cepr:Goal ;
  sh:sparql [
    sh:message "Goal com AerialThrow deve ter exatamente 2 pontos."@pt-BR ;
    sh:select """
      PREFIX cepr: <https://cepraea.app/ontology#>
      SELECT $this
      WHERE {
        $this cepr:hasShootingAction ?action ;
              cepr:points ?points .
        ?action a cepr:AerialThrow .
        FILTER(?points != 2)
      }
    """ ;
  ] .

cepr:ScoutLiveEntryShape a sh:NodeShape ;
  sh:targetClass cepr:ScoutLiveEntry ;
  sh:property [
    sh:path cepr:hasScoutPhase ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:in ( cepr:AT_POS cepr:DEF_POS cepr:TRANS_OF cepr:TRANS_DEF ) ;
    sh:message "ScoutLiveEntry deve usar um ScoutPhaseCode canonico do PWA."@pt-BR ;
  ] ;
  sh:property [
    sh:path cepr:hasFactualResult ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:class cepr:ScoutFactualResult ;
    sh:message "ScoutLiveEntry deve registrar exatamente um resultado factual canonico."@pt-BR ;
  ] ;
  sh:property [
    sh:path cepr:hasFlowContract ;
    sh:maxCount 1 ;
    sh:class cepr:ScoutFlowContract ;
    sh:message "ScoutLiveEntry deve apontar para um contrato de fluxo quando auditado."@pt-BR ;
  ] ;
  sh:sparql [
    sh:message "PASSIVO nao deve carregar tipo de finalizacao em ScoutLiveEntry."@pt-BR ;
    sh:select """
      PREFIX cepr: <https://cepraea.app/ontology#>
      SELECT $this
      WHERE {
        $this cepr:hasFactualResult cepr:result_passivo ;
              cepr:hasFinishType ?finishType .
      }
    """ ;
  ] ;
  sh:sparql [
    sh:message "Fluxo AT_POS.ARREMESSO.* deve usar fase AT_POS."@pt-BR ;
    sh:select """
      PREFIX cepr: <https://cepraea.app/ontology#>
      SELECT $this
      WHERE {
        $this cepr:hasFlowContract ?flow ;
              cepr:hasScoutPhase ?phase .
        FILTER(?flow IN (
          cepr:flow_at_pos_arremesso_arremesso,
          cepr:flow_at_pos_arremesso_finalizacao_6m_fav
        ))
        FILTER(?phase != cepr:AT_POS)
      }
    """ ;
  ] ;
  sh:sparql [
    sh:message "Fluxo TRANS_OF.ARREMESSO.ARREMESSO deve usar fase TRANS_OF."@pt-BR ;
    sh:select """
      PREFIX cepr: <https://cepraea.app/ontology#>
      SELECT $this
      WHERE {
        $this cepr:hasFlowContract cepr:flow_trans_of_arremesso_arremesso ;
              cepr:hasScoutPhase ?phase .
        FILTER(?phase != cepr:TRANS_OF)
      }
    """ ;
  ] ;
  sh:sparql [
    sh:message "AT_POS.ARREMESSO.ARREMESSO aceita apenas SIMPLES, GIRO ou AEREA como tipo de finalizacao."@pt-BR ;
    sh:select """
      PREFIX cepr: <https://cepraea.app/ontology#>
      SELECT $this
      WHERE {
        $this cepr:hasFlowContract cepr:flow_at_pos_arremesso_arremesso ;
              cepr:hasFinishType ?finishType .
        FILTER(?finishType NOT IN (cepr:finish_simples, cepr:finish_giro, cepr:finish_aerea))
      }
    """ ;
  ] ;
  sh:sparql [
    sh:message "TRANS_OF.ARREMESSO.ARREMESSO aceita apenas SIMPLES, GIRO, AEREA ou NAO_OBSERVADO como tipo de finalizacao."@pt-BR ;
    sh:select """
      PREFIX cepr: <https://cepraea.app/ontology#>
      SELECT $this
      WHERE {
        $this cepr:hasFlowContract cepr:flow_trans_of_arremesso_arremesso ;
              cepr:hasFinishType ?finishType .
        FILTER(?finishType NOT IN (cepr:finish_simples, cepr:finish_giro, cepr:finish_aerea, cepr:finish_nao_observado))
      }
    """ ;
  ] ;
  sh:sparql [
    sh:message "AT_POS.ARREMESSO.FINALIZACAO_6M_FAV deve usar tipo de finalizacao 6M quando informado."@pt-BR ;
    sh:select """
      PREFIX cepr: <https://cepraea.app/ontology#>
      SELECT $this
      WHERE {
        $this cepr:hasFlowContract cepr:flow_at_pos_arremesso_finalizacao_6m_fav ;
              cepr:hasFinishType ?finishType .
        FILTER(?finishType != cepr:finish_6m)
      }
    """ ;
  ] ;
  sh:sparql [
    sh:message "AT_POS.ARREMESSO.FINALIZACAO_6M_FAV nao aceita BLOQUEADO nem PASSIVO como resultado factual."@pt-BR ;
    sh:select """
      PREFIX cepr: <https://cepraea.app/ontology#>
      SELECT $this
      WHERE {
        $this cepr:hasFlowContract cepr:flow_at_pos_arremesso_finalizacao_6m_fav ;
              cepr:hasFactualResult ?result .
        FILTER(?result IN (cepr:result_bloqueado, cepr:result_passivo))
      }
    """ ;
  ] ;
  sh:sparql [
    sh:message "Resultado de arremesso observado exige tipo de finalizacao nos fluxos auditados."@pt-BR ;
    sh:select """
      PREFIX cepr: <https://cepraea.app/ontology#>
      SELECT $this
      WHERE {
        $this cepr:hasFlowContract ?flow ;
              cepr:hasFactualResult ?result .
        FILTER(?flow IN (
          cepr:flow_at_pos_arremesso_arremesso,
          cepr:flow_at_pos_arremesso_finalizacao_6m_fav,
          cepr:flow_trans_of_arremesso_arremesso
        ))
        FILTER(?result IN (
          cepr:result_gol,
          cepr:result_defendido,
          cepr:result_bloqueado,
          cepr:result_fora,
          cepr:result_trave
        ))
        FILTER NOT EXISTS { $this cepr:hasFinishType ?finishType }
      }
    """ ;
  ] .
