# =============================================================================
# CEPRAEA — variáveis de ambiente (exemplo)
# Copie para .env.local e preencha os valores reais.
# Nunca commitar .env.local.
# =============================================================================

# -- Supabase (obrigatório em dev/preview/prod) -------------------------------
# URL do projeto Supabase. Formato: https://<project-ref>.supabase.co
# Obtido em: Supabase Dashboard > Project Settings > API > Project URL
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Chave pública (publishable / anon). Pode ser exposta no client.
# Obtido em: Supabase Dashboard > Project Settings > API > Project API keys > anon/public
# Ausência destas duas variáveis dispara fail-fast [CEPR-AUTH-02:E001] no boot.
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOi...

# -- URL pública do app -------------------------------------------------------
# Usada pela tela de Settings; opcional fora de produção.
VITE_PUBLIC_URL=https://cepraea.vercel.app

# -- Cloudflare Turnstile (CEPR-AUTH-02E §12) ---------------------------------
# Site Key (público) — pode ser exposto no client. Cadastrado em:
# Cloudflare Dashboard > Turnstile > Widget "cepraea".
# Em ambientes de teste, usar a chave dummy "1x00000000000000000000AA" (always passes).
VITE_TURNSTILE_SITE_KEY=0x4AAAAAADZ7Ei2xLFibhh8r

# Token de bypass para E2E (Playwright). Quando definido, o widget injeta este
# token diretamente sem renderizar o iframe da Cloudflare.
# Em produção, esta variável SHALL NOT estar definida.
VITE_TURNSTILE_TEST_TOKEN=
