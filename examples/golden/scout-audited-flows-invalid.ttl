@prefix cepr: <https://cepraea.app/ontology#> .

cepr:AT_POS a cepr:ScoutPhase .
cepr:TRANS_OF a cepr:ScoutPhase .

cepr:result_gol a cepr:ScoutFactualResult .
cepr:result_bloqueado a cepr:ScoutFactualResult .
cepr:result_passivo a cepr:ScoutFactualResult .

cepr:finish_giro a cepr:ScoutFinishType .
cepr:finish_6m a cepr:ScoutFinishType .

cepr:flow_at_pos_arremesso_arremesso a cepr:ScoutFlowContract .
cepr:flow_at_pos_arremesso_finalizacao_6m_fav a cepr:ScoutFlowContract .
cepr:flow_trans_of_arremesso_arremesso a cepr:ScoutFlowContract .

cepr:audited_entry_at_pos_6m_finish_invalid a cepr:ScoutLiveEntry ;
  cepr:hasScoutPhase cepr:AT_POS ;
  cepr:hasFactualResult cepr:result_gol ;
  cepr:hasFinishType cepr:finish_6m ;
  cepr:hasFlowContract cepr:flow_at_pos_arremesso_arremesso .

cepr:audited_entry_6m_blocked_invalid a cepr:ScoutLiveEntry ;
  cepr:hasScoutPhase cepr:AT_POS ;
  cepr:hasFactualResult cepr:result_bloqueado ;
  cepr:hasFinishType cepr:finish_6m ;
  cepr:hasFlowContract cepr:flow_at_pos_arremesso_finalizacao_6m_fav .

cepr:audited_entry_6m_giro_finish_invalid a cepr:ScoutLiveEntry ;
  cepr:hasScoutPhase cepr:AT_POS ;
  cepr:hasFactualResult cepr:result_gol ;
  cepr:hasFinishType cepr:finish_giro ;
  cepr:hasFlowContract cepr:flow_at_pos_arremesso_finalizacao_6m_fav .

cepr:audited_entry_trans_of_wrong_phase_invalid a cepr:ScoutLiveEntry ;
  cepr:hasScoutPhase cepr:AT_POS ;
  cepr:hasFactualResult cepr:result_gol ;
  cepr:hasFinishType cepr:finish_giro ;
  cepr:hasFlowContract cepr:flow_trans_of_arremesso_arremesso .

cepr:audited_entry_at_pos_goal_missing_finish_invalid a cepr:ScoutLiveEntry ;
  cepr:hasScoutPhase cepr:AT_POS ;
  cepr:hasFactualResult cepr:result_gol ;
  cepr:hasFlowContract cepr:flow_at_pos_arremesso_arremesso .
