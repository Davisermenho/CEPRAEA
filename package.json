{
  "name": "cepraea-pwa",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:supabase": "bash scripts/run-supabase-tests.sh",
    "test:presence-token-batch:remote": "node scripts/validate-presence-token-batch.mjs",
    "check:supabase-foundation-scope": "bash scripts/check-supabase-foundation-scope.sh",
    "validate:supabase-foundation": "npm run check:supabase-foundation-scope && supabase db reset && npm run test:supabase && npm run build",
    "check:athlete-auth-foundation-scope": "bash scripts/check-athlete-auth-foundation-scope.sh",
    "test:athlete-auth": "bash scripts/run-athlete-auth-tests.sh",
    "validate:athlete-auth-foundation": "npm run check:athlete-auth-foundation-scope && supabase db reset && npm run test:athlete-auth && npm run build",
    "typecheck": "tsc --noEmit",
    "test:e2e": "bash scripts/run-e2e-local.sh",
    "test:smoke": "playwright test --config=playwright.smoke.config.ts --reporter=line",
    "test:smoke:scout:preview": "playwright test --config=playwright.scout-preview-smoke.config.ts --reporter=line",
    "deps:check": "npm ls --all",
    "check:ontology:semantics": "node scripts/check-ontology-semantics.mjs",
    "validate:ontology:formal": "bash scripts/validate-ontology-formal.sh",
    "check:ontology:runtime-alignment": "node scripts/check-ontology-runtime-alignment.mjs",
    "check:runtime-legacy": "bash scripts/check-runtime-legacy.sh",
    "validate:mvp:v1": "bash scripts/validate-mvp-v1.sh",
    "verify:supabase-config": "tsx scripts/verify-supabase-config.ts"
  },
  "dependencies": {
    "@e965/xlsx": "^0.20.3",
    "@supabase/supabase-js": "^2.87.1",
    "clsx": "^2.1.1",
    "idb": "^8.0.3",
    "lucide-react": "^0.511",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.0",
    "tailwind-merge": "^3.3.0",
    "zustand": "^5.0.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.1.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.1.3",
    "@types/react-dom": "^19.1.3",
    "@vitejs/plugin-react": "^4.5.0",
    "@vitest/coverage-v8": "^4.1.5",
    "dotenv": "^17.4.2",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.1.6",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.5",
    "workbox-window": "^7.3.0"
  }
}
