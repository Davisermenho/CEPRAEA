{
  "ontology": [
    "ontology/core.ttl"
  ],
  "datasets": {
    "minimal": "examples/minimal-data.ttl",
    "invalid": "examples/invalid-data.ttl",
    "golden_valid": "examples/golden/scout-live-real-valid.ttl",
    "golden_invalid": "examples/golden/scout-live-real-invalid.ttl",
