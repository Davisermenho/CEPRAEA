      "assert": {
        "row_count_eq": 1,
        "expected_rows": [
          {
            "entry": "https://cepraea.app/ontology#golden_live_entry_at_pos_spin_goal",
            "flowRuntimeCode": "AT_POS.ARREMESSO.ARREMESSO",
